# claude-agent 环境变量配置
# 复制此文件为 .env 并根据需要修改

# 镜像和容器名称
# CLAUDE_AGENT_IMAGE=songon/claude-agent
# CLAUDE_AGENT_NAME=claude-agent

# 挂载路径（默认值基于 $HOME）
# CLAUDE_CONFIG_DIR=$HOME/.claude
# SSH_DIR=$HOME/.ssh
# REPOSITORY_DIR=$HOME/repository
# CC_HOME_DIR=$HOME/cc-home
# DATA_DIR=./data

# 资源限制
# MEMORY_LIMIT=4g
# CPU_LIMIT=4

# 代理端口（0 表示禁用）
# PROXY_PORT=7897

# Claude Code HTTP 服务（同网段其他机器通过此端口调用容器内的 cc）
# 默认关闭。需要时设为 true 并配置 HTTP_API_KEY。
# HTTP_SERVICE_ENABLED=false
# HTTP_PORT=8765
# HTTP_API_KEY=                                # 不设置 = HTTP 服务启用时自动生成一个

